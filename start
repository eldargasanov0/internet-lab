#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

COMPOSE=(docker compose -f docker/docker-compose.local.yml)

log() { echo "👉 $*"; }
ok()  { echo "✅ $*"; }
err() { echo "❌ $*" >&2; }

ensure_env() {
  local target="$1"
  local example="${target}.example"

  if [[ -f "$target" ]]; then
    return 0
  fi

  if [[ ! -f "$example" ]]; then
    err "ERROR: $target is missing and $example was not found."
    exit 1
  fi

  log "Creating $target from $example"
  cp "$example" "$target"
  ok "Created $target from $example"
}

ensure_env docker/.env
ensure_env back/.env

log "Checking for git updates..."
if git fetch --quiet 2>/dev/null; then
  local_ref="$(git rev-parse HEAD)"
  if remote_ref="$(git rev-parse '@{u}' 2>/dev/null)"; then
    if [[ "$local_ref" != "$remote_ref" ]]; then
      log "Pulling latest changes..."
      git pull
      ok "Pulled latest changes"
    else
      ok "Already up to date."
    fi
  else
    log "No upstream branch configured; skipping git update."
  fi
else
  log "Could not reach remote; skipping git update."
fi

if [[ -n "$("${COMPOSE[@]}" ps -q --status running 2>/dev/null)" ]]; then
  log "Containers are running — rebuilding and restarting..."
else
  log "Containers are not running — building and starting..."
fi
"${COMPOSE[@]}" up -d --build

ok "Done. Containers are up."

log "Installing Composer dependencies..."
"${COMPOSE[@]}" run --rm --no-deps back composer install --no-interaction
"${COMPOSE[@]}" up -d
ok "Composer dependencies installed."

log "Starting migrations..."
if compgen -G "./back/migrations/*.php" > /dev/null; then
  docker exec -t internet-lab-back php bin/console doctrine:migrations:migrate --no-interaction
  ok "Migrations: Done"
else
  log "No migrations found; skipping"
fi

echo ""
echo ""
echo "🎉 Ready!"
