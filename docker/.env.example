PROJECT_NAME=internet-lab
COMPOSE_PROJECT_NAME=${PROJECT_NAME}-local

APP_ENV=dev
APP_DEBUG=true
APP_SECRET=secret

#nginx
NGINX_PORT=80
NGINX_HOST=${PROJECT_NAME}.local

#db
POSTGRES_DB=${PROJECT_NAME}
POSTGRES_USER=${PROJECT_NAME}
POSTGRES_PASSWORD=${PROJECT_NAME}
DATABASE_URL=postgresql://${PROJECT_NAME}:${PROJECT_NAME}@${PROJECT_NAME}-db:5432/${PROJECT_NAME}?serverVersion=17

# mail / Mailpit (compose service: mailer; SMTP 1025, UI 8025)
# Overrides back/.env MAILER_DSN=null://null so containers deliver to Mailpit
MAILER_DSN=smtp://mailer:1025

# Admin recipient for contact feedback notifications
ADMIN_EMAIL=admin@example.com
# From address for outbound emails (Mailpit accepts any valid address)
MAILER_FROM=noreply@example.com

# Messenger async transport (doctrine). Also set in back/.env; real env wins if set here.
# MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Generic OpenAI-compatible AI platform. Also documented in back/.env.example.
GENERIC_BASE_URL=https://api.example.com/v1
GENERIC_API_KEY=
GENERIC_MODEL=openai/gpt-4o-mini
